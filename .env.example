# Telegram
# Get BOT_TOKEN from @BotFather
BOT_TOKEN=your_bot_token_here
# CHANNEL_ID of the private channel (e.g., -100xxxxxxxxxx)
CHANNEL_ID=-100xxxxxxxxxx

# Supabase
# Find these in Project Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key_here

# Admin
# Comma-separated list of Telegram user IDs
ADMIN_IDS=123456789,987654321

# Welcome Message
# Use {first_name} as a placeholder
WELCOME_MESSAGE=Hey {first_name}! Welcome to the channel. We're glad to have you 🎉
WELCOME_BUTTON_TEXT=Join Community
WELCOME_BUTTON_URL=https://example.com
